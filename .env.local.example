# Copy this file to ".env.local" and fill in your values.
# Used ONLY for local development (npm run dev) and the type generator.
# .env.local is gitignored and never ends up in the built dashboard.js.

# URL of your Home Assistant instance (no trailing slash)
VITE_HASS_URL=http://homeassistant.local:8123

# A Long-Lived Access Token:
# HA → click your profile (bottom left) → "Security" tab → "Long-lived access tokens" → Create Token
VITE_HASS_TOKEN=paste-your-long-lived-access-token-here
